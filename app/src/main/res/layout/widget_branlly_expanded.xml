<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_panel_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView android:id="@+id/widget_action_top" style="@style/WidgetAction" />
    <TextView android:layout_width="1dp" android:layout_height="8dp" android:background="@drawable/widget_connection_line" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
        <TextView android:id="@+id/widget_action_upper_left" style="@style/WidgetAction" />
        <TextView android:layout_width="40dp" android:layout_height="1dp" android:layout_gravity="center_vertical" android:background="@drawable/widget_connection_line" />
        <TextView android:id="@+id/widget_action_upper_right" style="@style/WidgetAction" />
    </LinearLayout>

    <TextView android:layout_width="1dp" android:layout_height="8dp" android:background="@drawable/widget_connection_line" />
    <TextView android:id="@+id/widget_center" style="@style/WidgetCenter" android:contentDescription="@string/widget_close_menu" android:text="B" />
    <TextView android:layout_width="1dp" android:layout_height="8dp" android:background="@drawable/widget_connection_line" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
        <TextView android:id="@+id/widget_action_lower_left" style="@style/WidgetAction" />
        <TextView android:layout_width="40dp" android:layout_height="1dp" android:layout_gravity="center_vertical" android:background="@drawable/widget_connection_line" />
        <TextView android:id="@+id/widget_action_lower_right" style="@style/WidgetAction" />
    </LinearLayout>

    <TextView android:id="@+id/widget_action_bottom" style="@style/WidgetAction" />
</LinearLayout>
